# Node Environment
NODE_ENV=production

# Server Configuration
PORT=8080
HOST=0.0.0.0

# MongoDB Connection String
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/todo-db?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRE=7d

# App Service Configuration
# These are automatically set by Azure App Services
# WEBSITE_INSTANCE_ID=<auto-set>
# WEBSITE_NODE_DEFAULT_VERSION=24.x
